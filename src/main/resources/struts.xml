<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>

    <constant name="struts.devMode" value="true"/>

    <package name="default" extends="struts-default,json-default">

        <action name="home"
                class="com.expense.action.HomeAction">

            <result name="success">
                /home.jsp
            </result>

        </action>

        <action name="defaultExpense"
                class="com.expense.action.DefaultExpenseAction">

            <result name="success">
                /defaultExpense.jsp
            </result>

        </action>

        <action name="expenseItems"
                class="com.expense.action.ExpenseItemAction">

            <result type="json">
                <param name="root">itemList</param>
            </result>

        </action>
        <action name="defaultExpense"
        class="com.expense.action.DefaultExpenseAction">

            <result name="success">
                /defaultExpense.jsp
            </result>

            <result name="input">
                /defaultExpense.jsp
            </result>

            </action>
            <action name="expenseList"
                    class="com.expense.action.ExpenseListAction">

                <result name="success">
                    /expenseList.jsp
                </result>

            </action>
           <action name="loadExpense"
                class="com.expense.action.DefaultExpenseAction"
                method="loadExpense">

            <result type="json">
                <param name="root">expense</param>
            </result>

        </action>
        <action name="expenseView" class="com.expense.action.DefaultExpenseAction">
            <result name="success">/expenseView.jsp</result>
        </action>
        <action name="updateExpense" class="com.expense.action.DefaultExpenseAction" method="update">
            <result name="success">/expenseView.jsp</result>
        </action>
        <action name="deleteExpense" class="com.expense.action.DefaultExpenseAction" method="delete">
            <result name="success">/expenseView.jsp</result>
        </action>
        <action name="searchItem"
                class="com.expense.action.DefaultExpenseAction"
                method="searchByItem">
            <result type="json">
                <param name="root">list</param>
            </result>

        </action>
     <action name="exportPdf"
        class="com.expense.action.DefaultExpenseAction"
        method="exportPdf">
     </action>
     <action name="monthlyExpense" class="com.expense.action.MonthlyExpenseAction">
        <result name="success">/monthlyExpense.jsp</result>
    </action>
    <action name="loadDefaultExpenses"
                class="com.expense.action.MonthlyExpenseAction"
                method="loadDefaultExpenses">

            <result type="json">
                <param name="root">defaultExpenseList</param>
            </result>

    </action>
        
    </package>
    
</struts>